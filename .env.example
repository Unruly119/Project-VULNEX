# Project-VULNEX — Environment Variables Template
# Copy to .env and fill in real values

# Gemini API Key (Required)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini API Key — Backup (Optional but recommended)
# ใช้เฉพาะตอนสร้างรายงาน PDF/HTML เพื่อแยกโควต้าจากการวิเคราะห์บนหน้าจอ
# ถ้าไม่ใส่ ระบบจะใช้บทวิเคราะห์บนหน้าจอ / offline แทน
GEMINI_API_KEY_Backup=your_backup_api_key_here

# Model Selection (Optional)
# Default: gemini-2.5-flash-lite (free tier, fastest)
# Fallback order: gemini-2.5-flash-lite → gemini-2.5-flash → gemini-1.5-flash
# GEMINI_MODEL=gemini-2.5-flash-lite
