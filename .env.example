# Project-VULNEX — Environment Variables Template
# Copy to .env and fill in real values

# Gemini API Key (Required)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Gemini API Key — Backup (Optional but recommended)
# คีย์เสริมในพูล — ช่วยกระจายโควต้าตอนผู้ใช้เยอะ และใช้ตอนสร้างรายงาน PDF ก่อน
GEMINI_API_KEY_Backup=your_backup_api_key_here

# Gemini API Key — เสริมเพิ่มได้ถึง _8 (Optional)
# ยิ่งมีคีย์เยอะ ระบบยิ่งกระจายโหลด/หลบโควต้าได้ดี (auto cooldown เมื่อคีย์ไหนเต็ม)
# GEMINI_API_KEY_2=your_extra_api_key_here
# GEMINI_API_KEY_3=your_extra_api_key_here
# GEMINI_API_KEY_4..._8=your_extra_api_key_here

# OpenRouter API Key (Optional — ชั้น fallback ถัดจาก Gemini)
# ใช้เมื่อ Gemini หมดโควต้าทุกคีย์ แล้วค่อยตกไป offline rule-based เป็นชั้นสุดท้าย
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# Model Selection (Optional)
# Default cascade (ฉลาดสุดก่อน): gemini-2.5-flash → gemini-2.5-flash-lite → gemini-1.5-flash
# ตั้ง gemini-2.5-pro เพื่อดันตัวฉลาดสุดขึ้นหัวแถว (โควต้า free tier น้อย)
# GEMINI_MODEL=gemini-2.5-flash

# ── Supabase (ระบบสมาชิก: login/signup + เก็บประวัติการสแกน/audit) ──────────
# โปรเจกต์ = gepineqpjsltdtvgneiv  ·  ตารางอยู่หลัง RLS แบบ hardened
# SUPABASE_URL           = URL ของโปรเจกต์ (https://<ref>.supabase.co)
# SUPABASE_SERVICE_KEY   = secret key (sb_secret_…) — ข้าม RLS ได้ ⇒ ฝั่งเซิร์ฟเวอร์เท่านั้น
#                          ห้ามหลุดไป browser เด็ดขาด (บน Streamlit Cloud ใส่ใน st.secrets)
# SUPABASE_ANON_KEY      = publishable key (sb_publishable_…) — ปลอดภัยฝั่ง browser
#                          (ตอนนี้ระบบไม่ได้ใช้ เพราะ anon ถูกล็อกด้วย RLS ครบแล้ว)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_your_secret_key_here
SUPABASE_ANON_KEY=sb_publishable_your_publishable_key_here

# (Optional) ตั้ง =0 เฉพาะตอนทดสอบ local ผ่าน http:// เพื่อให้คุกกี้ login ทำงาน
# (production เป็น https อยู่แล้ว ปล่อยว่าง = คุกกี้เป็น Secure)
# VULNEX_COOKIE_SECURE=1

# ── Qdrant Cloud (RAG คลังความรู้ — src/rag/) ──────────────────────
# สร้าง Free Cluster ที่ https://cloud.qdrant.io แล้วคัดลอก Endpoint + API Key
# ใช้โดยระบบ RAG: คำถาม/ผลสแกน → ค้นคลังความรู้ (OWASP/CVE/NIST/CIS) → เติม prompt → Gemini
# ไม่ตั้งค่า = ระบบทำงานต่อได้ปกติ แค่ไม่มีบริบทจากคลังความรู้ (degrade gracefully)
Qdrant_Cluster_Endpoint=https://your-cluster-id.region.gcp.cloud.qdrant.io
Qdrant_API_Key=your_qdrant_api_key_here
